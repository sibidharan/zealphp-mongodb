{
    "name": "zealphp/mongodb",
    "description": "Async MongoDB driver for ZealPHP \u2014 Rust extension with PHP OOP library, non-blocking via eventfd + OpenSwoole coroutines",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "mongodb",
        "async",
        "rust",
        "zealphp",
        "openswoole",
        "coroutine",
        "eventfd"
    ],
    "homepage": "https://github.com/sibidharan/zealphp-mongodb",
    "authors": [
        {
            "name": "Sibidharan",
            "email": "sibidharan@selfmade.ninja"
        }
    ],
    "autoload": {
        "files": [
            "php/src/compat/bson_polyfill.php"
        ],
        "psr-4": {
            "ZealPHP\\MongoDB\\": "php/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ZealPHP\\MongoDB\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1",
        "mongodb/mongodb": "^1.15 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.7",
        "doctrine/coding-standard": "^12.0",
        "vimeo/psalm": "^6.0",
        "rector/rector": "^2.0"
    },
    "suggest": {
        "ext-zealphp-mongodb-ext": "Required for MongoDB operations (Rust extension)",
        "ext-openswoole": "Required for async coroutine mode (non-blocking MongoDB)"
    },
    "scripts": {
        "test": "phpunit",
        "check:cs": "phpcs",
        "check:psalm": "psalm --show-info=false --stats",
        "check:rector": "rector --dry-run",
        "checks": [
            "@check:cs",
            "@check:psalm",
            "@check:rector"
        ],
        "fix:cs": "phpcbf",
        "fix:rector": "rector process"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-plugin": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
